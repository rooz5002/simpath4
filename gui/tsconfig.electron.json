{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "outDir":           "electron-compiled",
    "rootDir":          "electron",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "noEmit":           false
  },
  "include": ["electron/*.ts"]
}
